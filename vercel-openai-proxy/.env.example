# OpenAI (required in Vercel → Environment Variables)
OPENAI_API_KEY=sk-...
# Optional; default gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Firebase Admin — paste the FULL JSON of your service account key (one line).
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Local dev only: set to "true" to skip Firebase (never use in production)
# SKIP_AUTH=true
